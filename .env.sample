# ============================================================================
# download.versatiles.org — updater configuration
#
# Copy this file to ".env" and fill in the values marked "REQUIRED".
# `npm run setup` reads this file to install & configure rclone;
# `npm run once` reads it to run the update pipeline.
# ============================================================================

# ── General ─────────────────────────────────────────────────────────────────
# REQUIRED. Public domain used to build absolute URLs in the site/url-lists.
DOMAIN="download.versatiles.org"

# ── Hetzner Storage Box (source, via SSH/SFTP) ──────────────────────────────
# REQUIRED. SSH/SFTP login of the Storage Box, as "user@host".
STORAGE_URL="u??????@u??????.your-storagebox.de"

# Absolute path to a private key that is authorized on the Storage Box.
# Used both by the updater (scan/hashing) and by setup.sh (rclone sftp remote).
# Default is ".ssh/storage" relative to the repo; override with an absolute path.
# SSH_KEY="$HOME/.ssh/id_ed25519"

# SSH/SFTP port of the Storage Box (Hetzner uses 23).
# SSH_PORT="23"

# ── Cloudflare R2 (destination, via S3 API) ─────────────────────────────────
# REQUIRED. Target bucket name (must already exist in R2).
R2_BUCKET="download-versatiles-org"

# REQUIRED. S3 credentials from your R2 API token (Object Read & Write).
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."

# REQUIRED. R2 S3 endpoint. Use the EU form (".eu.") for an EU-jurisdiction
# bucket. <ACCOUNT_ID> is shown on the R2 overview page.
R2_ENDPOINT="https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com"

# ── rclone remote names (you normally DON'T change these) ────────────────────
# These are just the LOCAL NAMES that `npm run setup` gives to the two rclone
# remotes it creates from the values above — they are not external references.
# The updater uses them to invoke rclone (e.g. `rclone copyto hetzner:… r2:…`).
# Keep them as-is unless the names clash with other remotes in your rclone.conf.
RCLONE_SFTP_REMOTE="hetzner"   # name for the Storage Box (SFTP) remote
RCLONE_R2_REMOTE="r2"          # name for the Cloudflare R2 (S3) remote

# ── Advanced (rarely needed) ────────────────────────────────────────────────
# Prefix stripped from absolute remote paths (/home/…) to form rclone SFTP
# keys. The default works when `rclone lsd hetzner:` lists the dataset folders
# directly. If they appear under `hetzner:home` instead, set this to "/".
# RCLONE_SFTP_STRIP_PREFIX="/home/"

# Path to the rclone executable (if not on PATH).
# RCLONE_BIN="rclone"
