{
  "name": "download.versatiles.org",
  "version": "1.0.0",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/versatiles-org/download.versatiles.org.git"
  },
  "scripts": {
    "build:site": "vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "dev": "tsx src/generate_testdata.ts && vite dev",
    "doc": "npm run doc-graph",
    "doc-graph": "vrt deps-graph | vrt doc-insert README.md '## Dependency Graph'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "once": "tsx --env-file=.env src/run_once.ts",
    "prepare": "svelte-kit sync",
    "preview:site": "vite preview",
    "setup": "bash scripts/setup.sh",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "upgrade": "vrt deps-upgrade && cd worker && vrt deps-upgrade && cd .."
  },
  "type": "module",
  "author": {
    "name": "Michael Kreil",
    "email": "github@michael-kreil.de",
    "url": "https://github.com/MichaelKreil"
  },
  "license": "MIT",
  "private": true,
  "overrides": {
    "cookie": ">=0.7.0"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.66.0",
    "sass": "^1.101.0",
    "svelte": "^5.56.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@versatiles/release-tool": "^2.8.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.6.0"
  }
}
