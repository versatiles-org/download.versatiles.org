# Public domain used to build absolute URLs.
DOMAIN="download.versatiles.org"

# Hetzner Storage Box SSH/SFTP target (user@host) and identity file.
STORAGE_URL="u??????-sub1@u??????-sub1.your-storagebox.de"
# SSH_KEY=".ssh/storage"   # default; relative to the repo dir, or an absolute path
# SSH_PORT="23"            # default (Hetzner Storage Box)

# rclone remote names (created by scripts/setup.sh) used to mirror data to R2.
RCLONE_SFTP_REMOTE="hetzner"
RCLONE_R2_REMOTE="r2"
R2_BUCKET="download-versatiles-org"

# Cloudflare R2 S3 credentials — used by scripts/setup.sh to write rclone.conf.
# Use the EU endpoint (…eu.r2…) because the bucket is EU-jurisdiction.
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_ENDPOINT="https://<ACCOUNT_ID>.eu.r2.cloudflarestorage.com"

# Optional: prefix stripped from remote (/home/...) paths to form rclone SFTP
# keys. Default works when `rclone lsd hetzner:` lists the dataset folders
# directly. Set to "/" if they appear under `hetzner:home` instead.
# RCLONE_SFTP_STRIP_PREFIX="/home/"
