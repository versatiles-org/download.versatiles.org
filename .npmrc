# Supply-chain hardening: do not run dependency lifecycle (pre/post)install
# scripts on npm install/ci. Our native deps (esbuild, @parcel/watcher, …) ship
# their binaries as separate platform packages, so they work without their
# install scripts. Note: this also skips the root `prepare` (svelte-kit sync) —
# CI runs `svelte-kit sync` explicitly, and dev/build/typecheck run it too.
ignore-scripts=true
