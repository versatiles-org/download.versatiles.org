{
  "name": "download.versatiles.org",
  "version": "1.0.0",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/versatiles-org/download.versatiles.org.git"
  },
  "scripts": {
    "check": "npm run lint && npm run test",
    "dev": "tsx --env-file=.env src/dev.ts",
    "doc": "npm run doc-graph",
    "doc-graph": "vrt deps-graph | vrt doc-insert README.md '## Dependency Graph'",
    "lint": "eslint . --color",
    "once": "tsx --env-file=.env src/run_once.ts",
    "test": "cross-env vitest run",
    "test-coverage": "cross-env vitest run --coverage",
    "upgrade": "vrt deps-upgrade"
  },
  "type": "module",
  "author": {
    "name": "Michael Kreil",
    "email": "github@michael-kreil.de",
    "url": "https://github.com/MichaelKreil"
  },
  "license": "MIT",
  "dependencies": {
    "handlebars": "^4.7.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "work-faster": "^2.5.7"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint__js": "^9.14.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@versatiles/release-tool": "^2.8.0",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "npm-check-updates": "^22.2.1",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
