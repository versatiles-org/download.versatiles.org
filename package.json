{
  "name": "download.versatiles.org",
  "version": "1.0.0",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/versatiles-org/download.versatiles.org.git"
  },
  "scripts": {
    "build:site": "vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && cd worker && npm run check",
    "dev": "tsx src/generate_testdata.ts && vite dev",
    "doc": "npm run doc-graph",
    "doc-graph": "vrt deps-graph | vrt doc-insert README.md '## Dependency Graph'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "once": "tsx --env-file=.env src/run_once.ts",
    "prepare": "svelte-kit sync",
    "preview:site": "vite preview",
    "setup": "bash scripts/setup.sh",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "upgrade": "ncu -u && npm install && cd worker && ncu -u && npm install && cd .."
  },
  "type": "module",
  "author": {
    "name": "Michael Kreil",
    "email": "github@michael-kreil.de",
    "url": "https://github.com/MichaelKreil"
  },
  "license": "MIT",
  "private": true,
  "overrides": {
    "cookie": ">=0.7.0"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "sass": "^1.101.0",
    "svelte": "^5.56.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@versatiles/release-tool": "^2.8.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.7.2"
  }
}
